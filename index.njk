---
title: Steven Simon
---

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="description" content="This is my portfolio.">
  <title>{{ title }}</title>
  <link rel="shortcut icon" type="image/x-icon" href="/images/favicon.ico" />

  <meta name="viewport" content="initial-scale=1, width=device-width">

  <!-- Styles -->
  <link rel="shortcut icon" type="image/x-icon" href="{{ '/images/favicon.ico' | url }}" />
  <link rel="stylesheet" href="{{ '/css/main.css' | url }}" type="text/css" charset="utf-8" />
  <link rel="stylesheet" href="{{ '/css/print.css' | url }}" type="text/css" media="print" />
  <link rel="stylesheet" href="{{ '/css/font-awesome.min.css' | url }}" />
  <noscript>
    <link rel="stylesheet" href="{{ '/css/noscript.css' | url }}" type="text/css" />
  </noscript>
</head>

<body>
  <!-- Hero Section -->
  <div id="hero">
    <div id="fade">
      <div class="wrapper feature">
        <header>
          <h1 class="rawLogo"><a href="https://srs815.github.io/portfolio">steven simon</a></h1>
          <div class="inside-wrapper">
            <p>{{ intro.text }}</p>
          </div>
          <nav>
            <a href="tel:3463730801" title="phone"><i class="fa fa-phone"></i></a>
            <a href="mailto:stevenraysimon@gmail.com" title="email"><i class="fa fa-envelope"></i></a>
            <a href="https://www.linkedin.com/in/steven-ray-simon" title="linkedin" target="_blank"><i class="fa fa-linkedin"></i></a>
            <a href="/resume" title="resume"><i class="fa fa-briefcase"></i></a>
            <a href="https://www.instagram.com/stevensimon50" title="instagram" target="_blank"><i class="fa fa-instagram"></i></a>
            <a href="https://stevenraysimon.github.io/caricatures/" title="caricatures" target="_blank"><i class="fa fa-smile-o"></i></a>
          </nav>
        </header>
      </div>
    </div>
  </div>

  <!-- Project Rows -->
  {% for project in projects %}
    {% include "row.njk" %}
    {% if not loop.last %}<hr>{% endif %}
  {% endfor %}

  <!-- Footer -->
  <footer>
    <div class="wrapper footer">
      <p>Designed and developed by Steven Simon <span id="date">2019</span></p>
    </div>
  </footer>

  <!-- Project Modals -->
  {% for project in projects %}
    {% include "modal.njk" %}
  {% endfor %}

  <!-- Scripts -->
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <script src="{{ '/js/modals.js' | url }}"></script>

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXXXX');
  </script>
</body>
</html>